<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="autocheck.Views.LoginPage"
             BackgroundColor="#0F172A"
             Title="Login">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="25">

        
            <VerticalStackLayout HorizontalOptions="Center">
                <Label Text="AutoCheck"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="#60A5FA"
                       HorizontalOptions="Center" />

                <Label Text="Sistema de Aluguel de Veículos"
                       FontSize="14"
                       TextColor="#94A3B8"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

           
            <Frame BackgroundColor="#1E293B"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <Label Text="Cadastro"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

           
                    <Frame BackgroundColor="#334155" CornerRadius="12" Padding="0">
                        <Entry x:Name="NomeEntry"
                               Placeholder="Nome completo"
                               TextColor="White"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                    <Frame BackgroundColor="#334155" CornerRadius="12" Padding="0">
                        <Entry x:Name="CpfEntry"
                               Placeholder="CPF"
                               Keyboard="Numeric"
                               TextColor="White"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                    <Frame BackgroundColor="#334155" CornerRadius="12" Padding="0">
                        <Entry x:Name="TelefoneEntry"
                               Placeholder="Telefone"
                               Keyboard="Telephone"
                               TextColor="White"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                    <Frame BackgroundColor="#334155" CornerRadius="12" Padding="0">
                        <Entry x:Name="EmailEntry"
                               Placeholder="Email"
                               TextColor="White"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                    <Frame BackgroundColor="#334155" CornerRadius="12" Padding="0">
                        <Entry x:Name="SenhaEntry"
                               Placeholder="Senha"
                               IsPassword="True"
                               TextColor="White"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <Button Text="Entrar"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    HeightRequest="55"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="15"
                    Clicked="OnLoginClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
