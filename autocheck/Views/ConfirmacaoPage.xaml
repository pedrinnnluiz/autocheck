<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="autocheck.Views.ConfirmacaoPage"
             BackgroundColor="#0F172A"
             Title="Confirmação">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- TÍTULO -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label Text="✔"
                       FontSize="28"
                       TextColor="#22C55E"/>
                <Label Text="Agendamento Realizado com Sucesso!"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#3B82F6"/>
            </HorizontalStackLayout>

            <!-- CARTÃO RESUMO -->
            <Frame BackgroundColor="#E0F2FE"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Resumo do Pedido"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#0F172A"
                           HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" BackgroundColor="#94A3B8"/>

                    <Label x:Name="NomeLabel" TextColor="#0F172A" FontSize="16"/>
                    <Label x:Name="InicioLabel" TextColor="#0F172A" FontSize="16"/>
                    <Label x:Name="FimLabel" TextColor="#0F172A" FontSize="16"/>
                    <Label x:Name="VeiculoLabel" TextColor="#0F172A" FontSize="16"/>

                    <BoxView HeightRequest="1" BackgroundColor="#94A3B8"/>

                    <Label x:Name="TotalLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1D4ED8"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>
            </Frame>

            <!-- BOTÃO FINAL -->
            <Button Text="Finalizar"
                    BackgroundColor="#1D4ED8"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="55"
                    FontAttributes="Bold"
                    FontSize="16"
                    Clicked="OnFinalizarClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
