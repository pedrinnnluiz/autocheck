<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:autocheck"
             x:Class="autocheck.App">

    <Application.Resources>

        <ResourceDictionary>

            <!-- 🎨 CORES DO TEMA -->
            <Color x:Key="Primary">#0D47A1</Color>
            <Color x:Key="Secondary">#1976D2</Color>
            <Color x:Key="Background">#FFFFFF</Color>
            <Color x:Key="Card">#F5F7FA</Color>
            <Color x:Key="TextPrimary">#333333</Color>

            <!-- 🧱 ESTILO PADRÃO DAS TELAS -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
            </Style>

            <!-- 🔘 BOTÕES AZUIS -->
            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HeightRequest" Value="50"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>

            <!-- ✏️ CAMPOS DE TEXTO -->
            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="TextColor" Value="Black"/>
                <Setter Property="PlaceholderColor" Value="#9E9E9E"/>
            </Style>

            <!-- ✅ MANTÉM SEUS DICIONÁRIOS ORIGINAIS -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>
</Application>
