<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="autocheck.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:autocheck.Views"
    Title="autocheck">


    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

  
    <ShellContent
        Title="Seleção"
        ContentTemplate="{DataTemplate views:SelecaoPage}"
        Route="SelecaoPage" />

    <ShellContent
        Title="Confirmação"
        ContentTemplate="{DataTemplate views:ConfirmacaoPage}"
        Route="ConfirmacaoPage" />

</Shell>
